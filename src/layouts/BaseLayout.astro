---
import '../styles/global.css';
import Header from '../components/organisms/Header.astro';
import Footer from '../components/organisms/Footer.astro';

export interface Props {
    title: string;
    description?: string;
    image?: string;
    overflowHidden?: boolean;
}

const { 
    title, 
    description = "O Instituto de Religião de Porto Alegre é um espaço acolhedor na Santana para o desenvolvimento de jovens adultos. Cursos práticos, novas amizades e atividades inesquecíveis.", 
    image = "https://images.unsplash.com/photo-1521737604893-d14cc237f11d?q=80&w=1200&auto=format&fit=crop", // Default preview image
    overflowHidden = true 
} = Astro.props;
---

<html lang="pt-BR" data-theme="lofi">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/instituto-logo.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        
        <!-- Open Graph / Meta / Facebook / WhatsApp -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={image} />
        <meta property="og:site_name" content="Instituto Hub" />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={Astro.url} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={image} />

		<title>{title}</title>
        
        <!-- Dark Mode Global Injector -->
        <script is:inline>
            (function() {
                const getThemePreference = () => {
                    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                        return localStorage.getItem('theme');
                    }
                    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                };
                if (getThemePreference() === 'dark') {
                    document.documentElement.classList.add('dark');
                    document.documentElement.setAttribute('data-theme', 'dracula'); // Optional default dark theme for daisyUI elements
                }
            })();
        </script>
	</head>
	<body class={`min-h-screen relative font-body ${overflowHidden ? 'overflow-x-hidden' : ''}`} style="background-image: radial-gradient(var(--color-principal) 1px, transparent 1px); background-size: 20px 20px;">
        <div class="noise-overlay"></div>
		
		<Header />

		<slot />

		<Footer />

        <!-- Floating WhatsApp Button Global (Mobile Focused) -->
        <a href="https://wa.me/5551999999999?text=Ol%C3%A1%2C%20estou%20no%20site%20do%20Instituto%20Hub%20e%20gostaria%20de%20mais%20informa%C3%A7%C3%B5es%21" 
           target="_blank" 
           rel="noopener noreferrer" 
           aria-label="Entrar em contato via WhatsApp"
           class="fixed bottom-6 right-6 lg:hidden z-[100] bg-[#25D366] text-white p-4 rounded-full border-4 border-principal neo-shadow flex items-center justify-center hover:bg-[#128C7E] transition-all hover:-translate-y-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        </a>
	</body>
</html>
