---
import BaseLayout from '../layouts/BaseLayout.astro';
import AulaCard from '../components/molecules/AulaCard.astro';
---

<BaseLayout title="Aulas - Instituto Hub">

		<main class="container mx-auto px-4 py-8 md:py-16 max-w-7xl flex flex-col gap-12 sm:gap-16 relative z-10">
            <!-- Header Banner -->
            <section class="bg-instituto-yellow border-4 border-instituto-blue neo-shadow p-5 sm:p-8 animate-slide-up transform -rotate-1 relative lg:mt-4 group hover:rotate-0 transition-transform duration-300 max-w-4xl mx-auto mb-4 sm:mb-8 w-full">
                <div class="absolute -top-3 -right-3 sm:-top-4 sm:-right-4 w-10 h-10 sm:w-12 sm:h-12 bg-white border-4 border-instituto-blue rounded-full z-20 flex items-center justify-center text-xl sm:text-2xl neo-shadow group-hover:scale-110 transition-transform">📚</div>
                <h1 class="text-[2.5rem] sm:text-5xl md:text-6xl font-heading font-black text-instituto-blue uppercase leading-[0.9] tracking-tighter">
                    Aulas<br/>
                    <span class="text-white" style="-webkit-text-stroke: 1.5px var(--color-instituto-blue);">Ministradas</span>
                </h1>
                <p class="mt-4 text-sm sm:text-base md:text-lg font-bold text-instituto-blue border-l-4 border-white pl-3 sm:pl-4">
                    Conheça a grade curricular deste semestre e inscreva-se nas classes do Instituto de Religião.
                </p>
            </section>

            <!-- Tabs Menu (Navegação dos Dias) -->
            <div class="grid grid-cols-2 sm:flex sm:flex-wrap gap-3 sm:gap-4 mt-4 sm:mt-6 justify-center animate-slide-up z-20 relative w-full max-w-[340px] sm:max-w-none mx-auto sm:px-2">
                <button class="tab-btn btn bg-instituto-yellow hover:bg-instituto-yellow text-instituto-blue hover:border-instituto-blue border-4 border-instituto-blue rounded-none uppercase font-black tracking-widest sm:tracking-wider neo-shadow text-sm sm:text-base py-0 min-h-0 h-12 sm:h-14 transition-all translate-y-0 w-full sm:w-auto sm:px-8" data-target="tab-terca">Terça</button>
                <button class="tab-btn btn bg-white hover:bg-slate-100 text-instituto-blue hover:border-instituto-blue border-4 border-instituto-blue rounded-none uppercase font-black tracking-widest sm:tracking-wider text-sm sm:text-base py-0 min-h-0 h-12 sm:h-14 transition-all translate-y-1 hover:translate-y-0 hover:neo-shadow w-full sm:w-auto sm:px-8" data-target="tab-quarta">Quarta</button>
                <button class="tab-btn btn bg-white hover:bg-slate-100 text-instituto-blue hover:border-instituto-blue border-4 border-instituto-blue rounded-none uppercase font-black tracking-widest sm:tracking-wider text-sm sm:text-base py-0 min-h-0 h-12 sm:h-14 transition-all translate-y-1 hover:translate-y-0 hover:neo-shadow w-full sm:w-auto sm:px-8" data-target="tab-quinta">Quinta</button>
                <button class="tab-btn btn bg-white hover:bg-slate-100 text-instituto-blue hover:border-instituto-blue border-4 border-instituto-blue rounded-none uppercase font-black tracking-widest sm:tracking-wider text-sm sm:text-base py-0 min-h-0 h-12 sm:h-14 transition-all translate-y-1 hover:translate-y-0 hover:neo-shadow w-full sm:w-auto sm:px-8" data-target="tab-sabado">Sábado</button>
            </div>

            <!-- Conteúdo das Abas (Aulas) -->
            <div class="animate-slide-up delay-100 mt-4 sm:mt-6 min-h-[40vh] relative z-10 w-full mb-12">
                
                <!-- Aba: Terça-feira -->
                <section id="tab-terca" class="tab-content grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8 max-w-6xl mx-auto">
                    <!-- Aula Card 1 -->
                    <AulaCard 
                        relCode="REL 250"
                        modality="Presencial"
                        title="Jesus Cristo e o Evangelho Eterno"
                        instructor="Prof. Almeida"
                        time="19:30"
                        description="Estudo focado na vida, missão preordenada, ministério mortal e Expiação do Salvador."
                        imageSrc="https://images.unsplash.com/photo-1491841550275-ad7854e35ca6?q=80&w=1000&auto=format&fit=crop"
                        imageAlt="Aula Jesus Cristo"
                        tagRotateClass="-rotate-3"
                        theme="yellow"
                    />

                    <!-- Aula Card 1B (Cópia) -->
                    <AulaCard 
                        relCode="REL 211"
                        modality="Presencial"
                        title="O Novo Testamento"
                        instructor="Ir. Mendes"
                        time="20:30"
                        description="Explore os ensinamentos dos apóstolos e a Igreja primitiva no Novo Testamento."
                        imageSrc="https://images.unsplash.com/photo-1544928147-79a2dbc1f389?q=80&w=1000&auto=format&fit=crop"
                        imageAlt="O Novo Testamento"
                        tagRotateClass="rotate-2"
                        theme="yellow"
                    />
                </section>

                <!-- Aba: Quarta-feira -->
                <section id="tab-quarta" class="tab-content hidden grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8 max-w-6xl mx-auto">
                    <!-- Aula Card 2 -->
                    <AulaCard 
                        relCode="REL 225"
                        modality="100% Online"
                        title="Oeste Americano"
                        instructor="Prof. Vieira"
                        time="18:00"
                        description="Estudo da jornada pioneira, desafios e a consolidação da Igreja no cenário histórico do século 19."
                        imageSrc="https://images.unsplash.com/photo-1543452601-57d8fccb6cfa?q=80&w=1000&auto=format&fit=crop"
                        imageAlt="Aula Oeste Americano"
                        tagRotateClass="rotate-3"
                        theme="blue"
                        zoomUrl="https://zoom.us"
                    />

                    <!-- Aula Card 2B -->
                    <AulaCard 
                        relCode="REL 390R"
                        modality="100% Online"
                        title="Mulheres nas Escrituras"
                        instructor="Ir. Cardoso"
                        time="19:30"
                        description="Aprenda a influência, as experiências e o papel essencial das mulheres ao longo das escrituras."
                        imageSrc="https://images.unsplash.com/photo-1579781404111-9a74a1d4719b?q=80&w=1000&auto=format&fit=crop"
                        imageAlt="Mulheres nas Escrituras"
                        tagRotateClass="-rotate-1"
                        theme="blue"
                        zoomUrl="https://zoom.us"
                    />
                </section>

                <!-- Aba: Quinta-feira -->
                <section id="tab-quinta" class="tab-content hidden grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8 max-w-6xl mx-auto">
                    <!-- Aula Card 3 -->
                    <AulaCard 
                        relCode="REL 121"
                        modality="Híbrido"
                        title="O Livro de Mórmon"
                        instructor="Ir. Ribeiro"
                        time="20:00"
                        description="Uma análise profunda dos eventos e doutrinas contidas na primeira parte do Livro de Mórmon. Venha fortalecer seu testemunho!"
                        imageSrc="https://images.unsplash.com/photo-1456513080510-7bf3a84b82f8?q=80&w=1000&auto=format&fit=crop"
                        imageAlt="Estudo Escrituras"
                        tagRotateClass="rotate-2"
                        theme="blue"
                        zoomUrl="https://zoom.us"
                    />
                </section>

                <!-- Aba: Sábado -->
                <section id="tab-sabado" class="tab-content hidden grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8 max-w-6xl mx-auto">
                    <!-- Aula Card 4 -->
                    <AulaCard 
                        relCode="REL 234"
                        modality="Presencial"
                        title="Casamento Eterno"
                        instructor="Casal Silva"
                        time="10:00"
                        description="Princípios e habilidades necessárias para estabelecer um casamento feliz e fundado no evangelho. Ideal para noivos e recém-casados."
                        imageSrc="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=1000&auto=format&fit=crop"
                        imageAlt="Casamento Eterno"
                        tagRotateClass="rotate-3"
                        theme="yellow"
                    />

                    <!-- Aula Card 5 -->
                    <AulaCard 
                        relCode="REL 150"
                        modality="Presencial"
                        title="O Evangelho Restaurado"
                        instructor="Bispo Lima"
                        time="11:30"
                        description="Mergulhe na história e nas revelações fundamentais da Restauração nestes últimos dias."
                        imageSrc="https://images.unsplash.com/photo-1493612276216-ee3925520721?q=80&w=1000&auto=format&fit=crop"
                        imageAlt="O Evangelho Restaurado"
                        tagRotateClass="-rotate-3"
                        theme="yellow"
                    />
                </section>

            </div>
        </main>

        <!-- Script Isolado Para Alternância de Abas -->
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const tabBtns = document.querySelectorAll('.tab-btn');
                const tabContents = document.querySelectorAll('.tab-content');

                tabBtns.forEach(btn => {
                    btn.addEventListener('click', () => {
                        const targetId = btn.getAttribute('data-target');

                        // Oculta todas as sections / Mostra a Section alvo
                        tabContents.forEach(content => {
                            if (content.id === targetId) {
                                content.classList.remove('hidden');
                                content.classList.add('grid');
                            } else {
                                content.classList.add('hidden');
                                content.classList.remove('grid');
                            }
                        });

                        // Reseta o estilo dos botões inativos e Ilumina a aba ativa
                        tabBtns.forEach(b => {
                            if (b === btn) {
                                b.classList.add('bg-instituto-yellow', 'hover:bg-instituto-yellow', 'neo-shadow', 'translate-y-0');
                                b.classList.remove('bg-white', 'hover:bg-slate-100', 'translate-y-1', 'hover:translate-y-0', 'hover:neo-shadow');
                            } else {
                                b.classList.add('bg-white', 'hover:bg-slate-100', 'translate-y-1', 'hover:translate-y-0', 'hover:neo-shadow');
                                b.classList.remove('bg-instituto-yellow', 'hover:bg-instituto-yellow', 'neo-shadow', 'translate-y-0');
                            }
                        });
                    });
                });
            });
        </script>
</BaseLayout>
