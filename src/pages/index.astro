---
import '../styles/global.css';
---

<html lang="pt-BR" data-theme="lofi">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Instituto Hub - Design System</title>
	</head>
	<body class="min-h-screen">
		<main class="max-w-md mx-auto p-4 flex flex-col gap-6 items-center">
			
			<header class="text-center mt-12 mb-4">
				<h1 class="text-5xl font-extrabold text-instituto-blue tracking-tight">Instituto</h1>
				<p class="text-sm font-semibold text-slate-500 uppercase tracking-widest mt-1">Porto Alegre</p>
			</header>

			<!-- Box estilo "Recorte/Post" -->
			<div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-200 flex flex-col gap-4 w-full">
				<h2 class="text-xl font-black border-b pb-2 border-slate-100 flex items-center justify-between">
					<span>Próximos Eventos</span> 
					<span class="text-2xl">🌟</span>
				</h2>
				<ul class="flex flex-col gap-3">
					<li class="flex items-center gap-3">
						<div class="bg-instituto-yellow/20 text-instituto-yellow-hover font-black px-3 py-1 rounded-lg text-sm">03/03</div>
						<div class="font-bold text-slate-700">Volta às Aulas</div>
					</li>
					<li class="flex items-center gap-3">
						<div class="bg-instituto-blue/10 text-instituto-blue px-3 py-1 rounded-lg text-sm font-black">07/03</div>
						<div class="font-bold text-slate-700">Calourada JAS</div>
					</li>
				</ul>
				
				<button class="btn border-none bg-instituto-yellow text-slate-900 hover:bg-instituto-yellow-hover w-full rounded-xl font-bold text-lg mt-2">
					Ver Programação Completa
				</button>
			</div>

            <!-- Box Tema Aulas -->
            <div class="bg-instituto-blue text-white rounded-2xl p-6 shadow-md flex flex-col gap-4 w-full relative overflow-hidden">
				<!-- Detalhe de fundo para dar charme -->
				<div class="absolute -right-10 -top-10 w-32 h-32 bg-white/10 rounded-full blur-2xl"></div>

				<h2 class="text-xl font-black flex items-center gap-2 relative z-10">
                    <span class="text-2xl">📚</span> Grade de Cursos
                </h2>
                <p class="text-sm text-blue-100 opacity-90 relative z-10">
                    Encontre a classe de Instituto mais próxima de você, seja presencial ou 100% online.
                </p>
				
				<button class="btn bg-white text-instituto-blue border-none hover:bg-slate-100 w-full rounded-xl font-bold mt-2 relative z-10 shadow-sm">
					Escolher Turma
				</button>
			</div>

		</main>
	</body>
</html>
