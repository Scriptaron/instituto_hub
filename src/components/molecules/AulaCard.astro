---
export interface Props {
  relCode: string;
  modality: string;
  title: string;
  instructor: string;
  time: string;
  description: string;
  imageSrc: string;
  imageAlt: string;
  tagRotateClass?: string;
  theme?: "fundamental" | "eletivo";
  whatsAppUrl?: string;
  zoomUrl?: string;
}

const {
  relCode,
  modality,
  title,
  instructor,
  time,
  description,
  imageSrc,
  imageAlt,
  tagRotateClass = "-rotate-3",
  theme = "fundamental",
  whatsAppUrl = "#",
  zoomUrl
} = Astro.props;

const isFundamental = theme === "fundamental";
const tagColorClass = isFundamental 
  ? "bg-destaque text-principal border-principal neo-shadow-yellow" 
  : "bg-principal text-white border-white neo-shadow";
const dotColorClass = isFundamental ? "bg-destaque" : "bg-principal";
---

<div class="bg-white border-4 border-principal neo-shadow flex flex-col group relative h-full">
    <div class="h-36 sm:h-44 md:h-40 border-b-4 border-principal overflow-hidden relative bg-slate-100">
        <img src={imageSrc} loading="lazy" class="w-full h-full object-cover grayscale-[0.2] contrast-125 group-hover:grayscale-0 transition-all duration-500" alt={imageAlt}>
        <span class={`absolute top-4 left-4 font-black px-3 py-1 font-heading border-2 transform ${tagRotateClass} text-sm z-10 ${tagColorClass}`}>
            {relCode}
        </span>
        <span class="absolute top-4 right-4 bg-white border-2 border-principal text-principal font-black uppercase text-[10px] px-2 py-1 neo-shadow mt-2 sm:mt-0 z-10">
            {modality}
        </span>
    </div>

    <div class="p-5 flex-1 flex flex-col gap-4">
        <div>
            <h3 class="text-xl sm:text-2xl font-black font-heading text-slate-800 uppercase leading-none mb-2 mt-1">{title}</h3>
            <div class="flex items-center gap-2 mb-3 mt-3">
                <div class={`w-2 h-2 ${dotColorClass} border border-principal rounded-full`}></div>
                <p class="font-bold text-principal text-sm">{instructor} • {time}</p>
            </div>
            <p class="text-slate-700 font-medium text-sm line-clamp-3">{description}</p>
        </div>
        
        <div class="flex flex-col gap-2 mt-auto pt-4 border-t-2 border-dashed border-principal">
            <a href="https://forms.office.com/Pages/ResponsePage.aspx?id=s-7mYddfqkquPGHo3rCbeeM0om7MfKhBu1hqe0-54JxURUMwSlpUU0ExVzZaNUw1NjQ4REhWWlIxSC4u" target="_blank" rel="noopener noreferrer" class="btn w-full bg-principal hover:bg-principal text-white border-4 border-principal rounded-none uppercase font-black tracking-widest text-xs neo-shadow-sm min-h-0 h-10">
                Matricular-se
            </a>
            {zoomUrl ? (
            <div class="grid grid-cols-2 gap-2 mt-1">
                <a href={whatsAppUrl} target="_blank" rel="noopener noreferrer" class="btn bg-[#25D366] hover:bg-[#128C7E] text-white border-4 border-principal rounded-none uppercase font-black tracking-tighter sm:tracking-normal text-[10px] sm:text-xs min-h-0 h-10 px-0 flex items-center justify-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                    Whats
                </a>
                <a href={zoomUrl} target="_blank" rel="noopener noreferrer" class="btn bg-[#2D8CFF] hover:bg-[#0B5CFF] text-white border-4 border-principal rounded-none uppercase font-black tracking-tighter sm:tracking-normal text-[10px] sm:text-xs min-h-0 h-10 px-0 flex items-center justify-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14v-4z"/><rect x="3" y="6" width="12" height="12" rx="2" ry="2"/></svg>
                    Zoom
                </a>
            </div>
            ) : (
            <a href={whatsAppUrl} target="_blank" rel="noopener noreferrer" class="btn w-full bg-[#25D366] hover:bg-[#128C7E] text-white border-4 border-principal rounded-none uppercase font-black tracking-widest text-xs min-h-0 h-10 gap-2 mt-1 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                Grupo Whats
            </a>
            )}
            
            <a href="#" target="_blank" rel="noopener noreferrer" class="btn w-full bg-white hover:bg-slate-50 text-principal border-4 border-principal rounded-none uppercase font-black tracking-widest text-xs min-h-0 h-10 mt-1 flex items-center justify-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                Recuperação
            </a>
        </div>
    </div>
</div>
