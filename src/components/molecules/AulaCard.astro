---
export interface Props {
  relCode: string;
  modality: string;
  title: string;
  instructor: string;
  time: string;
  description: string;
  imageSrc: string;
  imageAlt: string;
  tagRotateClass?: string;
  theme?: "yellow" | "blue";
  enrollLink?: string;
  whatsAppUrl?: string;
  zoomUrl?: string;
}

const {
  relCode,
  modality,
  title,
  instructor,
  time,
  description,
  imageSrc,
  imageAlt,
  tagRotateClass = "-rotate-3",
  theme = "yellow",
  enrollLink = "https://myinstitute.churchofjesuschrist.org",
  whatsAppUrl = "#",
  zoomUrl
} = Astro.props;

const isYellow = theme === "yellow";
const tagColorClass = isYellow 
  ? "bg-instituto-yellow text-instituto-blue border-instituto-blue neo-shadow-yellow" 
  : "bg-instituto-blue text-white border-white neo-shadow";
const dotColorClass = isYellow ? "bg-instituto-yellow" : "bg-instituto-blue";
---

<div class="bg-white border-4 border-instituto-blue neo-shadow flex flex-col group relative h-full">
    <div class="h-36 sm:h-44 md:h-40 border-b-4 border-instituto-blue overflow-hidden relative bg-slate-100">
        <img src={imageSrc} loading="lazy" class="w-full h-full object-cover grayscale-[0.2] contrast-125 group-hover:grayscale-0 transition-all duration-500" alt={imageAlt}>
        <span class={`absolute top-4 left-4 font-black px-3 py-1 font-heading border-2 transform ${tagRotateClass} text-sm z-10 ${tagColorClass}`}>
            {relCode}
        </span>
        <span class="absolute top-4 right-4 bg-white border-2 border-instituto-blue text-instituto-blue font-black uppercase text-[10px] px-2 py-1 neo-shadow mt-2 sm:mt-0 z-10">
            {modality}
        </span>
    </div>

    <div class="p-5 flex-1 flex flex-col gap-4">
        <div>
            <h3 class="text-xl sm:text-2xl font-black font-heading text-slate-800 uppercase leading-none mb-2 mt-1">{title}</h3>
            <div class="flex items-center gap-2 mb-3 mt-3">
                <div class={`w-2 h-2 ${dotColorClass} border border-instituto-blue rounded-full`}></div>
                <p class="font-bold text-instituto-blue text-sm">{instructor} • {time}</p>
            </div>
            <p class="text-slate-700 font-medium text-sm line-clamp-3">{description}</p>
        </div>
        
        <div class="flex flex-col gap-2 mt-auto pt-4 border-t-2 border-dashed border-instituto-blue">
            <a href={enrollLink} target="_blank" rel="noopener noreferrer" class="btn w-full bg-instituto-blue hover:bg-instituto-blue-dark text-white border-4 border-instituto-blue rounded-none uppercase font-black tracking-widest text-xs neo-shadow-sm min-h-0 h-10">
                Matricular-se
            </a>
            {zoomUrl ? (
            <div class="grid grid-cols-2 gap-2 mt-1">
                <a href={whatsAppUrl} target="_blank" rel="noopener noreferrer" class="btn bg-[#25D366] hover:bg-[#128C7E] text-white border-4 border-instituto-blue rounded-none uppercase font-black tracking-tighter sm:tracking-wider text-[9px] sm:text-[10px] min-h-0 h-10 px-0 sm:px-1">
                    Grupo Whats
                </a>
                <a href={zoomUrl} target="_blank" rel="noopener noreferrer" class="btn bg-blue-500 hover:bg-blue-600 text-white border-4 border-instituto-blue rounded-none uppercase font-black tracking-tighter sm:tracking-wider text-[9px] sm:text-[10px] min-h-0 h-10 px-0 sm:px-1">
                    📹 Zoom
                </a>
            </div>
            ) : (
            <a href={whatsAppUrl} target="_blank" rel="noopener noreferrer" class="btn w-full bg-[#25D366] hover:bg-[#128C7E] text-white border-4 border-instituto-blue rounded-none uppercase font-black tracking-widest text-xs min-h-0 h-10 gap-2 mt-1">
                📱 Grupo Whats
            </a>
            )}
        </div>
    </div>
</div>
