---
export interface Props {
    align?: 'left' | 'right';
    
    dotColorClass?: string;
    dotShadowClass?: string;
    
    cardBgClass?: string;
    cardShadowClass?: string;
    cardExtraClass?: string;
    
    connectorBorderClass?: string;
    
    tagLabel: string;
    tagClass?: string;
    
    price?: string;
    
    dateMain: string;
    dateSub: string;
    
    title: string;
    titleClass?: string;
    
    detailsText: string;
    detailsClass?: string;
    detailsIconSvg?: string;
    
    buttonText: string;
    buttonClass?: string;
    buttonUrl?: string;
}

const {
    align = 'right',
    dotColorClass = 'bg-principal',
    dotShadowClass = 'shadow-[4px_4px_0_var(--color-principal)]',
    
    cardBgClass = 'bg-white',
    cardShadowClass = 'shadow-[6px_6px_0_var(--color-principal)]',
    cardExtraClass = '',
    
    connectorBorderClass = 'border-principal',
    
    tagLabel,
    tagClass = 'bg-principal text-white shadow-[2px_2px_0_var(--color-principal)]',
    
    price,
    
    dateMain,
    dateSub,
    
    title,
    titleClass = 'text-principal group-hover:text-destaque',
    
    detailsText,
    detailsClass = 'text-slate-500',
    detailsIconSvg,
    
    buttonText,
    buttonClass = 'bg-white text-principal shadow-[4px_4px_0_var(--color-principal)]',
    buttonUrl
} = Astro.props;

const isLeft = align === 'left';
const rowClass = isLeft ? 'lg:flex-row-reverse' : 'lg:flex-row';
const emptyDivClass = isLeft ? 'mr-auto' : 'ml-auto';
---

<div class={`relative flex items-center lg:justify-between w-full mb-12 sm:mb-16 flex-col ${rowClass} pl-24 lg:pl-0`}>
    <div class={`hidden lg:block w-[45%] ${emptyDivClass}`}></div>
    
    <!-- Bolinha do Timeline com Borda Grossa -->
    <div class={`absolute left-8 lg:left-1/2 transform -translate-x-1/2 lg:-translate-x-1/2 w-8 h-8 sm:w-12 sm:h-12 border-4 border-principal rounded-full z-10 flex flex-col justify-center items-center ${dotColorClass} ${dotShadowClass}`}>
    </div>
    
    <!-- Cartão do Evento -->
    <div class={`w-full lg:w-[45%] border-4 border-principal p-6 sm:p-8 hover:-translate-y-1 transition-all relative group ${cardBgClass} ${cardShadowClass} ${cardExtraClass}`}>
        
        {isLeft ? (
            <>
                <!-- Traço Conector Horizontal Oculto em Mobile, visivel esq no Desktop -->
                <div class={`hidden lg:block absolute top-[1.5rem] sm:top-[2rem] -right-12 w-12 h-3 bg-principal border-b-4 -z-10 ${connectorBorderClass}`}></div>
                <!-- Traço Conector Horizontal Mobile (mantem sempre à esquerda nas bolinhas) -->
                <div class={`lg:hidden absolute top-[1.5rem] sm:top-[2rem] -left-8 w-8 h-3 bg-principal border-b-4 -z-10 ${connectorBorderClass}`}></div>
            </>
        ) : (
            <!-- Traço Conector Horizontal -->
            <div class={`absolute top-[1.5rem] sm:top-[2rem] -left-8 lg:-left-12 w-8 lg:w-12 h-3 bg-principal border-b-4 -z-10 ${connectorBorderClass}`}></div>
        )}
        
        <div class="flex items-center gap-2 mb-6 flex-wrap">
            <span class={`border-2 border-principal px-3 py-1 text-[10px] sm:text-xs font-black uppercase transition-transform hover:-translate-y-0.5 ${tagClass}`}>{tagLabel}</span>
            {price && (
                <span class="text-xs sm:text-sm font-bold text-principal line-through opacity-50 ml-2">{price}</span>
            )}
            <div class="ml-auto flex items-center bg-white border-4 border-principal shadow-[4px_4px_0_var(--color-principal)] px-3 py-1.5 sm:py-2 group-hover:-translate-y-1 transition-transform">
                <span class="text-xl sm:text-2xl font-black text-principal tracking-tighter">{dateMain}</span>
                <span class="text-[10px] sm:text-xs font-black text-principal uppercase ml-2 pl-2 border-l-4 border-principal leading-none">{dateSub}</span>
            </div>
        </div>
        
        <h3 class={`text-2xl sm:text-3xl font-black uppercase leading-[1.1] mb-3 transition-colors break-words ${titleClass}`}>{title}</h3>
        
        <p class={`text-sm font-bold mb-6 flex items-center gap-2 ${detailsClass}`}>
            {detailsIconSvg ? (
                <Fragment set:html={detailsIconSvg} />
            ) : (
                <svg class="text-principal shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            )}
            {detailsText}
        </p>
        
        {buttonUrl ? (
            <a href={buttonUrl} target="_blank" rel="noopener noreferrer" class={`btn sm:btn-md w-full sm:w-auto border-4 border-principal rounded-none uppercase font-black tracking-widest text-[10px] sm:text-xs transition-transform active:translate-y-1 active:shadow-none inline-flex flex-wrap items-center justify-center ${buttonClass}`}>
                {buttonText}
            </a>
        ) : (
            <button class={`btn sm:btn-md w-full sm:w-auto border-4 border-principal rounded-none uppercase font-black tracking-widest text-[10px] sm:text-xs transition-transform active:translate-y-1 active:shadow-none ${buttonClass}`}>
                {buttonText}
            </button>
        )}
    </div>
</div>
