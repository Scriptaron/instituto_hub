---
// Header Organism
const pathname = new URL(Astro.request.url).pathname;

// Helper function to determine if a link is active
const isActive = (path: string) => {
  if (path === '/' && pathname === '/') return true;
  if (path !== '/' && pathname.startsWith(path)) return true;
  return false;
};

// Styling for active state: heavy border, yellow background, solid shadow vs default state
const activeClass = 'bg-destaque border-4 border-principal font-black neo-shadow-yellow translate-x-[-2px] translate-y-[-2px]';
const defaultClass = 'hover:bg-slate-100 rounded-none hover:text-principal border-4 border-transparent';
---
<div class="navbar bg-white border-b-2 border-principal sticky top-0 z-50 animate-slide-up px-4 md:px-8">
    <div class="navbar-start">
        <div class="dropdown">
            <div tabindex="0" role="button" aria-label="Abrir Menu Principal" aria-expanded="false" class="btn btn-ghost lg:hidden p-2 text-principal">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" /></svg>
            </div>
            <!-- Improved Mobile Menu UX -->
            <ul tabindex="0" class="menu dropdown-content mt-4 z-[1] bg-white border-2 border-principal rounded-none w-[85vw] max-w-[320px] neo-shadow text-principal font-bold font-heading uppercase text-xl p-2 gap-2">
                <li><a href="/" class={`py-4 px-6 rounded-none border-2 border-transparent ${isActive('/') ? 'bg-destaque border-principal font-black' : 'hover:bg-slate-100 hover:border-principal'}`}>Home</a></li>
                <li><a href="/aulas" class={`py-4 px-6 rounded-none border-2 border-transparent ${isActive('/aulas') ? 'bg-destaque border-principal font-black' : 'hover:bg-slate-100 hover:border-principal'}`}>Aulas</a></li>
                <li><a href="/cronograma" class={`py-4 px-6 rounded-none border-2 border-transparent ${isActive('/cronograma') ? 'bg-destaque border-principal font-black' : 'hover:bg-slate-100 hover:border-principal'}`}>Cronograma</a></li>
                <li><a href="/sobre" class={`py-4 px-6 rounded-none border-2 border-transparent ${isActive('/sobre') ? 'bg-destaque border-principal font-black' : 'hover:bg-slate-100 hover:border-principal'}`}>Sobre</a></li>
            </ul>
        </div>
        <a href="/" class="btn btn-ghost hover:bg-transparent text-2xl md:text-3xl font-black font-heading text-principal uppercase tracking-tighter px-0 md:px-4">Inst. Hub</a>
    </div>
    <div class="navbar-center hidden lg:flex">
        <ul class="menu menu-horizontal px-1 text-principal font-bold font-heading uppercase text-lg gap-4 items-center">
            <li><a href="/" class={`${isActive('/') ? activeClass : defaultClass}`}>Home</a></li>
            <li><a href="/aulas" class={`${isActive('/aulas') ? activeClass : defaultClass}`}>Aulas</a></li>
            <li><a href="/cronograma" class={`${isActive('/cronograma') ? activeClass : defaultClass}`}>Cronograma</a></li>
            <li><a href="/sobre" class={`${isActive('/sobre') ? activeClass : defaultClass}`}>Sobre</a></li>
        </ul>
    </div>
    <div class="navbar-end flex justify-end gap-3 sm:gap-4 items-center pr-2">
        <!-- Theme Toggle Button -->
        <button id="theme-toggle" aria-label="Alternar Tema Escuro" class="btn bg-white hover:bg-slate-100 text-principal border-2 border-principal rounded-none neo-shadow min-h-0 h-10 w-10 sm:h-12 sm:w-12 p-0 flex items-center justify-center">
            <svg id="theme-icon-sun" class="hidden w-6 h-6 sm:w-7 sm:h-7" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <svg id="theme-icon-moon" class="w-6 h-6 sm:w-7 sm:h-7" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
        </button>

        <!-- WhatsApp CTA -->
        <a href="https://wa.me/5551999999999?text=Ol%C3%A1%2C%20tenho%20d%C3%BAvidas%20sobre%20o%20Instituto%21" target="_blank" rel="noopener noreferrer" class="btn bg-[#25D366] text-white border-2 border-principal hover:bg-[#128C7E] hover:border-principal rounded-none font-black font-heading uppercase tracking-widest text-xs lg:text-sm neo-shadow hidden lg:flex gap-2 min-h-0 h-10 sm:h-12 px-4 lg:px-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            Dúvidas?
        </a>
    </div>
</div>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        const toggleBtn = document.getElementById('theme-toggle');
        const sunIcon = document.getElementById('theme-icon-sun');
        const moonIcon = document.getElementById('theme-icon-moon');
        const html = document.documentElement;

        // Function to update icon visibility
        const updateIcons = (isDark) => {
            if (isDark) {
                sunIcon.classList.remove('hidden');
                moonIcon.classList.add('hidden');
            } else {
                sunIcon.classList.add('hidden');
                moonIcon.classList.remove('hidden');
            }
        };

        // Initialize state based on script injected from BaseLayout
        const isCurrentlyDark = html.classList.contains('dark');
        updateIcons(isCurrentlyDark);

        toggleBtn.addEventListener('click', () => {
            const willBeDark = !html.classList.contains('dark');
            
            if (willBeDark) {
                html.classList.add('dark');
                html.setAttribute('data-theme', 'dracula'); // Optional DaisyUI trigger
                localStorage.setItem('theme', 'dark');
            } else {
                html.classList.remove('dark');
                html.setAttribute('data-theme', 'lofi');
                localStorage.setItem('theme', 'light');
            }

            updateIcons(willBeDark);
        });
    });
</script>
